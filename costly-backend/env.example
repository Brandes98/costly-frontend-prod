# ============================================================
# .env.example — Copiar a .env y completar los valores
# NO subir el .env real a Git
# ============================================================

# Base de datos
DATABASE_URL="postgresql://costly_user:costly_pass@localhost:5432/costly_db?schema=public"

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="reemplazar-con-valor-seguro-de-64-caracteres"
JWT_EXPIRES_IN="8h"

# Redis
REDIS_URL="redis://localhost:6379"

# Servidor
PORT=3000
NODE_ENV=development

# CORS — orígenes permitidos separados por coma
ALLOWED_ORIGINS="http://localhost:5173"
